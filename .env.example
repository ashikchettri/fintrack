# Copy to .env (git-ignored). Local dev values only — never real secrets.
POSTGRES_USER=fintrack
POSTGRES_PASSWORD=fintrack_local
POSTGRES_DB=fintrack

# SonarQube local analysis (docker compose --profile quality up -d sonarqube)
# Generate a token via UI (http://localhost:9000 → My Account → Security) or API.
SONAR_ADMIN_PASSWORD=change-me
SONAR_TOKEN=squ_your_token_here

# Change if something else (e.g. a native Postgres) already uses 5432
POSTGRES_HOST_PORT=5432

# Verification email sending — defaults hit local Mailpit (docker compose, inbox :8025).
# For Gmail: set MAIL_HOST=smtp.gmail.com MAIL_PORT=587 MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true and a Google App Password (never the account password).
MAIL_FROM=no-reply@example.com
MAIL_USERNAME=
MAIL_PASSWORD=

# Resend transactional email (optional — provider chain: SMTP creds > Resend key > Mailpit)
RESEND_API_KEY=
RESEND_FROM=
